# StatementCSV environment variables (example).
# Copy to .env (gitignored) and fill in real values. Do NOT commit real secrets.
#
# ---------------------------------------------------------------------------
# Supabase Postgres (Prisma) — billing/account database.
# Get these from Supabase: Project Settings > Database > Connection string.
# ---------------------------------------------------------------------------
#
# DATABASE_URL: pooled connection (Supavisor/PgBouncer, port 6543). Used by the
# app at runtime. The `pgbouncer=true` flag is required for the pooled connection.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL: direct connection (port 5432). Used by `prisma migrate` / `prisma studio`.
# If you only have one connection string, set DIRECT_URL to the same value as DATABASE_URL.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# Supabase Auth (identity/session). Publishable values only — safe for the browser.
# Project Settings > API. NEVER put the service-role/secret key in NEXT_PUBLIC vars.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="<supabase-publishable-key>"

# ---------------------------------------------------------------------------
# Stripe (subscriptions). SECRET values — server-only, never NEXT_PUBLIC.
# Price IDs come from the live products you created in the Stripe dashboard.
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_MINIMUM="price_..."
STRIPE_PRICE_PLUS="price_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_PRO_PLUS_2000="price_..."
STRIPE_PRICE_PRO_PLUS_3000="price_..."

# Public base URL used for Stripe success/cancel/return redirects (no secret).
NEXT_PUBLIC_APP_URL="https://statementcsv.com"

# ---------------------------------------------------------------------------
# AI assist (optional; existing). Not required for the billing DB foundation.
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=""
# AI_ASSIST_MODEL=""
