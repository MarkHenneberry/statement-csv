// StatementCSV billing/account schema (Supabase Postgres).
//
// Wired in this pass: Prisma is installed and the client generates from this
// schema. Nothing connects at build time — the app never imports the Prisma
// client, so `npm run build` works without a live database. Migrations and the
// DB sanity script connect only when DATABASE_URL is set (see README.md).
//
// Supabase connection strings (do NOT commit real values):
//   - DATABASE_URL : pooled connection (PgBouncer, port 6543) used at runtime.
//   - DIRECT_URL   : direct connection (port 5432) used by `prisma migrate`.
// If DIRECT_URL is unset, Prisma falls back to DATABASE_URL for migrations.
//
// PRIVACY: these tables store ONLY safe operational metadata. We never store
// transaction rows, raw PDF text, PDF files, rendered images, or AI prompts/
// responses. See src/lib/billing/README.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PlanKey {
  free
  minimum
  plus
  pro
  pro_plus_2000
  pro_plus_3000
}

enum SubscriptionStatus {
  free
  active
  past_due
  canceled
  incomplete
}

enum ConversionStatus {
  verified
  review
  failed
}

enum BalanceStatus {
  passed
  review
  limited
}

enum LedgerReason {
  verified_conversion
  review_export
  refund
  monthly_reset
  manual_adjustment
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account     BillingAccount?
  conversions Conversion[]
  ledger      PageCreditLedger[]
}

model BillingAccount {
  userId               String             @id
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  planKey              PlanKey            @default(free)
  status               SubscriptionStatus @default(free)
  // Populated by Stripe in a later pass; nullable until then.
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  currentPeriodStart   DateTime           @default(now())
  currentPeriodEnd     DateTime
  // Snapshot of the plan allowance for the active period.
  monthlyPageAllowance Int                @default(0)
  pagesUsedThisPeriod  Int                @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model Conversion {
  id        String           @id @default(cuid())
  // Nullable so an anonymous free preview can still be recorded.
  userId    String?
  user      User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Optional, treat as sensitive — never required by billing. No statement content.
  originalFilename String?
  pageCount        Int
  status           ConversionStatus
  balanceStatus    BalanceStatus?
  creditsCharged   Int             @default(0)
  chargedAt        DateTime?
  exportedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  ledger PageCreditLedger[]

  @@index([userId])
}

model PageCreditLedger {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversionId String?
  conversion   Conversion?  @relation(fields: [conversionId], references: [id], onDelete: SetNull)
  // + adds credits (monthly_reset / refund), - consumes them (a conversion).
  deltaPages   Int
  reason       LedgerReason
  createdAt    DateTime     @default(now())

  @@index([userId])
}
